# name: test/sql/tbbo.test
# description: read_dbn_tbbo() table function
# group: [sql]
# TBBO uses Mbp1Msg + RType::Mbp1. Without metadata-schema parsing
# read_dbn_tbbo and read_dbn_mbp1 return the same data on either file;
# Phase 3 will gate them via Metadata.schema.

statement error
SELECT * FROM read_dbn_tbbo('test/data/test_data.tbbo.dbn');
----
read_dbn_tbbo

require dbn

query I
SELECT count(*) FROM read_dbn_tbbo('test/data/test_data.tbbo.dbn');
----
2

query IIIIRRIIIIIIITT
SELECT
    epoch_ns(ts_event),
    epoch_ns(ts_recv),
    instrument_id::BIGINT,
    publisher_id::BIGINT,
    bid_price,
    ask_price,
    bid_size::BIGINT,
    ask_size::BIGINT,
    bid_ct::BIGINT,
    ask_ct::BIGINT,
    flags::BIGINT,
    ts_in_delta,
    sequence::BIGINT,
    action,
    side
FROM read_dbn_tbbo('test/data/test_data.tbbo.dbn')
ORDER BY ts_event, sequence;
