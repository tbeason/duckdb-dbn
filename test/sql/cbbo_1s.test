# name: test/sql/cbbo_1s.test
# description: read_dbn_cbbo_1s() table function
# group: [sql]

statement error
SELECT * FROM read_dbn_cbbo_1s('test/data/test_data.cbbo-1s.dbn');
----
read_dbn_cbbo_1s

require dbn

query I
SELECT count(*) FROM read_dbn_cbbo_1s('test/data/test_data.cbbo-1s.dbn');
----
2

# bid_pb / ask_pb are u16 publisher bitmasks; Julia DBN.jl treats those bytes
# as u32 bid_ct/ask_ct so only the low 16 bits compare.
query IIIIRITIRRIIII
SELECT
    epoch_ns(ts_event),
    epoch_ns(ts_recv),
    instrument_id::BIGINT,
    publisher_id::BIGINT,
    price,
    size::BIGINT,
    side,
    flags::BIGINT,
    bid_price,
    ask_price,
    bid_size::BIGINT,
    ask_size::BIGINT,
    bid_pb::BIGINT,
    ask_pb::BIGINT
FROM read_dbn_cbbo_1s('test/data/test_data.cbbo-1s.dbn')
ORDER BY ts_event;
----
