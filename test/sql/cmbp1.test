    price,
    size::BIGINT,
    action,
    side,
    flags::BIGINT,
    ts_in_delta,
    bid_price,
    ask_price,
    bid_size::BIGINT,
    ask_size::BIGINT,
    bid_pb::BIGINT,
    ask_pb::BIGINT
