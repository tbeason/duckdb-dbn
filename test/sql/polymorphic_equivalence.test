# name: test/sql/polymorphic_equivalence.test
# description: For every fixture, assert that polymorphic read_dbn(path)
#              returns exactly the same rows as the schema-specific
#              read_dbn_<schema>(path). This is the only blanket-coverage
#              test of the per-schema header_layout switch added in
#              Phase 5-A stage 2 (the switch in ReadDbnBind that dispatches
#              kHeaderLayoutOhlcv / Statistics / Standard based on
#              md.schema). If any schema's polymorphic dispatch is wrong,
#              its EXCEPT here will surface non-zero.
# group: [sql]

require dbn

# ──────────────────────────────────────────────────────────────────────────
# Standard-layout schemas (most)
# ──────────────────────────────────────────────────────────────────────────

query I
SELECT count(*) FROM (
  (SELECT * FROM read_dbn_trades('test/data/test_data.trades.dbn'))
  EXCEPT (SELECT * FROM read_dbn('test/data/test_data.trades.dbn'))
  UNION ALL
  (SELECT * FROM read_dbn('test/data/test_data.trades.dbn'))
  EXCEPT (SELECT * FROM read_dbn_trades('test/data/test_data.trades.dbn'))
)
----
0

