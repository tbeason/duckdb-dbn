read_dbn_mbp1

require dbn

query I
SELECT count(*) FROM read_dbn_mbp1('test/data/test_data.mbp-1.dbn');
----
2

query IIIIRRIIIIIIITT
SELECT
    epoch_ns(ts_event),
    epoch_ns(ts_recv),
    instrument_id::BIGINT,
    publisher_id::BIGINT,
    bid_price,
    ask_price,
    bid_size::BIGINT,
    ask_size::BIGINT,
    bid_ct::BIGINT,
    ask_ct::BIGINT,
    flags::BIGINT,
    ts_in_delta,
    sequence::BIGINT,
    action,
    side
FROM read_dbn_mbp1('test/data/test_data.mbp-1.dbn')
ORDER BY ts_event, sequence;
