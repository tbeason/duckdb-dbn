4

query IIIIRITIRRIIIII
SELECT
    epoch_ns(ts_event),
    epoch_ns(ts_recv),
    instrument_id::BIGINT,
    publisher_id::BIGINT,
    price,
    size::BIGINT,
    side,
    flags::BIGINT,
    bid_price,
    ask_price,
    bid_size::BIGINT,
    ask_size::BIGINT,
    bid_ct::BIGINT,
    ask_ct::BIGINT,
    sequence::BIGINT
FROM read_dbn_bbo_1m('test/data/test_data.bbo-1m.dbn')
ORDER BY ts_event, sequence
LIMIT 2;
