# name: test/sql/phase3c_real.test
# description: Real-data coverage for the three previously-smoke-only schemas
# group: [sql]

#              (cbbo_1m, ohlcv_eod, tcbbo) plus a zero-row trades fixture.
#              Fixtures are generated by tools/generate_fixtures.jl and
#              golden CSVs by tools/generate_expected.py from dbn-cli.

require dbn

# -- cbbo_1m --------------------------------------------------------------

# Row count from the new fixture.
query I
SELECT count(*) FROM read_dbn_cbbo_1m('test/data/test_data.cbbo-1m.dbn')
----
4

# Full-row EXCEPT vs golden CSV in both directions — zero rows of difference.
query I
SELECT count(*) FROM (
    (
        SELECT epoch_ns(ts_event) AS ts_event_ns,
               epoch_ns(ts_recv)  AS ts_recv_ns,
               instrument_id, publisher_id, price, size, side, flags,
               bid_price, ask_price, bid_size, ask_size, bid_pb, ask_pb
        FROM read_dbn_cbbo_1m('test/data/test_data.cbbo-1m.dbn')
        EXCEPT
        SELECT * FROM read_csv('test/data/expected/test_data.cbbo-1m.csv',
            header=true,
            columns={
                'ts_event_ns':'BIGINT','ts_recv_ns':'BIGINT',
                'instrument_id':'UINTEGER','publisher_id':'USMALLINT',
                'price':'DOUBLE','size':'UINTEGER','side':'VARCHAR','flags':'UTINYINT',
                'bid_price':'DOUBLE','ask_price':'DOUBLE',
                'bid_size':'UINTEGER','ask_size':'UINTEGER',
                'bid_pb':'INTEGER','ask_pb':'INTEGER'
            })
    )
    UNION ALL
    (
        SELECT * FROM read_csv('test/data/expected/test_data.cbbo-1m.csv',
            header=true,
            columns={
                'ts_event_ns':'BIGINT','ts_recv_ns':'BIGINT',
                'instrument_id':'UINTEGER','publisher_id':'USMALLINT',
                'price':'DOUBLE','size':'UINTEGER','side':'VARCHAR','flags':'UTINYINT',
                'bid_price':'DOUBLE','ask_price':'DOUBLE',
                'bid_size':'UINTEGER','ask_size':'UINTEGER',
                'bid_pb':'INTEGER','ask_pb':'INTEGER'
            })
        EXCEPT
        SELECT epoch_ns(ts_event) AS ts_event_ns,
               epoch_ns(ts_recv)  AS ts_recv_ns,
               instrument_id, publisher_id, price, size, side, flags,
               bid_price, ask_price, bid_size, ask_size, bid_pb, ask_pb
        FROM read_dbn_cbbo_1m('test/data/test_data.cbbo-1m.dbn')
    )
)
----
0

# Filter pushdown — distinct instrument_ids in the fixture.
query II
SELECT instrument_id, size
FROM read_dbn_cbbo_1m('test/data/test_data.cbbo-1m.dbn')
WHERE instrument_id IN (5482, 6002)
ORDER BY instrument_id
----
5482	11
6002	13

# Polymorphic dispatch through read_dbn() — same row count.
query I
SELECT count(*) FROM read_dbn('test/data/test_data.cbbo-1m.dbn')
----
4

# -- tcbbo ----------------------------------------------------------------

query I
SELECT count(*) FROM read_dbn_tcbbo('test/data/test_data.tcbbo.dbn')
----
4

query I
SELECT count(*) FROM (
    (
        SELECT epoch_ns(ts_event) AS ts_event_ns,
               epoch_ns(ts_recv)  AS ts_recv_ns,
               instrument_id, publisher_id, price, size, action, side,
               flags, ts_in_delta,
               bid_price, ask_price, bid_size, ask_size, bid_pb, ask_pb
        FROM read_dbn_tcbbo('test/data/test_data.tcbbo.dbn')
        EXCEPT
        SELECT * FROM read_csv('test/data/expected/test_data.tcbbo.csv',
            header=true,
            columns={
                'ts_event_ns':'BIGINT','ts_recv_ns':'BIGINT',
                'instrument_id':'UINTEGER','publisher_id':'USMALLINT',
                'price':'DOUBLE','size':'UINTEGER',
                'action':'VARCHAR','side':'VARCHAR',
                'flags':'UTINYINT','ts_in_delta':'INTEGER',
                'bid_price':'DOUBLE','ask_price':'DOUBLE',
                'bid_size':'UINTEGER','ask_size':'UINTEGER',
                'bid_pb':'INTEGER','ask_pb':'INTEGER'
            })
    )
    UNION ALL
    (
        SELECT * FROM read_csv('test/data/expected/test_data.tcbbo.csv',
            header=true,
            columns={
                'ts_event_ns':'BIGINT','ts_recv_ns':'BIGINT',
                'instrument_id':'UINTEGER','publisher_id':'USMALLINT',
                'price':'DOUBLE','size':'UINTEGER',
                'action':'VARCHAR','side':'VARCHAR',
                'flags':'UTINYINT','ts_in_delta':'INTEGER',
                'bid_price':'DOUBLE','ask_price':'DOUBLE',
                'bid_size':'UINTEGER','ask_size':'UINTEGER',
                'bid_pb':'INTEGER','ask_pb':'INTEGER'
            })
        EXCEPT
        SELECT epoch_ns(ts_event) AS ts_event_ns,
               epoch_ns(ts_recv)  AS ts_recv_ns,
               instrument_id, publisher_id, price, size, action, side,
               flags, ts_in_delta,
               bid_price, ask_price, bid_size, ask_size, bid_pb, ask_pb
        FROM read_dbn_tcbbo('test/data/test_data.tcbbo.dbn')
    )
)
----
0

# Filter + projection pushdown together.
query R
SELECT price FROM read_dbn_tcbbo('test/data/test_data.tcbbo.dbn')
WHERE instrument_id = 6003
----
3720.625

query I
SELECT count(*) FROM read_dbn('test/data/test_data.tcbbo.dbn')
----
4

# -- ohlcv_eod ------------------------------------------------------------

query I
SELECT count(*) FROM read_dbn_ohlcv_eod('test/data/test_data.ohlcv-eod.dbn')
----
2

query I
SELECT count(*) FROM (
    (
        SELECT epoch_ns(ts_event) AS ts_event_ns,
               instrument_id, publisher_id,
               open, high, low, close, volume
        FROM read_dbn_ohlcv_eod('test/data/test_data.ohlcv-eod.dbn')
        EXCEPT
        SELECT * FROM read_csv('test/data/expected/test_data.ohlcv-eod.csv',
            header=true,
            columns={
                'ts_event_ns':'BIGINT',
                'instrument_id':'UINTEGER','publisher_id':'USMALLINT',
                'open':'DOUBLE','high':'DOUBLE','low':'DOUBLE','close':'DOUBLE',
                'volume':'UBIGINT'
            })
    )
    UNION ALL
    (
        SELECT * FROM read_csv('test/data/expected/test_data.ohlcv-eod.csv',
            header=true,
            columns={
                'ts_event_ns':'BIGINT',
                'instrument_id':'UINTEGER','publisher_id':'USMALLINT',
                'open':'DOUBLE','high':'DOUBLE','low':'DOUBLE','close':'DOUBLE',
                'volume':'UBIGINT'
            })
        EXCEPT
        SELECT epoch_ns(ts_event) AS ts_event_ns,
               instrument_id, publisher_id,
               open, high, low, close, volume
        FROM read_dbn_ohlcv_eod('test/data/test_data.ohlcv-eod.dbn')
    )
)
----
0

# Polymorphic dispatch — schema 13 (OhlcvEod) routes to the ohlcv-eod handler.
query I
SELECT count(*) FROM read_dbn('test/data/test_data.ohlcv-eod.dbn')
----
2

# -- trades.empty (zero-row, Standard layout) -----------------------------

# Zero rows, but the schema columns are still exposed.
query I
SELECT count(*) FROM read_dbn_trades('test/data/test_data.trades.empty.dbn')
----
0

# Type-bind is data-independent: types resolve even with no records.
query TTTT
SELECT typeof(ts_event), typeof(instrument_id), typeof(price), typeof(side)
FROM (SELECT * FROM read_dbn_trades('test/data/test_data.trades.empty.dbn') LIMIT 0)
UNION ALL VALUES ('NONE'::VARCHAR, 'NONE'::VARCHAR, 'NONE'::VARCHAR, 'NONE'::VARCHAR)
LIMIT 1
----
NONE	NONE	NONE	NONE

# Polymorphic + filter pushdown on the empty fixture — still zero rows, no error.
query I
SELECT count(*) FROM read_dbn('test/data/test_data.trades.empty.dbn') WHERE instrument_id = 5482
----
0

# dbn_metadata works on the empty fixture (header is intact).
query IT
SELECT version::INTEGER, schema
FROM dbn_metadata('test/data/test_data.trades.empty.dbn')
----
3	trades
