# name: test/sql/mbo.test
# description: read_dbn_mbo() table function
# group: [sql]

statement error
SELECT * FROM read_dbn_mbo('test/data/test_data.mbo.dbn');
----
read_dbn_mbo

require dbn

query I
SELECT count(*) FROM read_dbn_mbo('test/data/test_data.mbo.dbn');
----
2

# Wire-format interpretation (databento-cpp's MboMsg). Julia DBN.jl's
# read_mbo_msg has a layout bug: it reads bytes 16-23 as ts_recv and bytes
# 40-47 as price, opposite of the wire format.
query IIIIIRITTIIII
SELECT
    epoch_ns(ts_event),
    epoch_ns(ts_recv),
    instrument_id::BIGINT,
    publisher_id::BIGINT,
    order_id::BIGINT,
    price,
    size::BIGINT,
    flags::BIGINT,
    channel_id::BIGINT,
    action,
    side,
    ts_in_delta,
    sequence::BIGINT
FROM read_dbn_mbo('test/data/test_data.mbo.dbn')
ORDER BY ts_event, sequence;
----
