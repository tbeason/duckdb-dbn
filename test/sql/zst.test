# name: test/sql/zst.test
# description: .dbn.zst decompression via DuckDB's bundled zstd
# group: [sql]

require dbn

# Same trades data, .dbn vs .dbn.zst — row counts and content match.
query I
SELECT count(*) FROM read_dbn_trades('test/data/test_data.trades.v2.dbn.zst');
----
2

# Compare zst vs uncompressed via EXCEPT — should be empty in both directions.
query I
SELECT count(*) FROM (
    SELECT * FROM read_dbn_trades('test/data/test_data.trades.dbn')
    EXCEPT
    SELECT * FROM read_dbn_trades('test/data/test_data.trades.v2.dbn.zst')
);
----
0

query I
SELECT count(*) FROM (
    SELECT * FROM read_dbn_trades('test/data/test_data.trades.v2.dbn.zst')
    EXCEPT
    SELECT * FROM read_dbn_trades('test/data/test_data.trades.dbn')
);
----
0

# MBP-1 round trip
query I
SELECT count(*) FROM (
    SELECT * FROM read_dbn_mbp1('test/data/test_data.mbp-1.dbn')
    EXCEPT
    SELECT * FROM read_dbn_mbp1('test/data/test_data.mbp-1.v2.dbn.zst')
);
----
0

# MBO round trip (v3 layout — uncompressed fixture also v3)
query I
SELECT count(*) FROM (
    SELECT * FROM read_dbn_mbo('test/data/test_data.mbo.dbn')
    EXCEPT
    SELECT * FROM read_dbn_mbo('test/data/test_data.mbo.v3.dbn.zst')
);
----
0

# OHLCV round trip
query I
SELECT count(*) FROM (
    SELECT * FROM read_dbn_ohlcv_1s('test/data/test_data.ohlcv-1s.dbn')
    EXCEPT
    SELECT * FROM read_dbn_ohlcv_1s('test/data/test_data.ohlcv-1s.v2.dbn.zst')
);
----
0

# Definition .zst is a different DBN version from the uncompressed fixture
# (v3 vs v2), so we can't EXCEPT-equate the two — the v2→v3 upgrade path
# produces non-identical values in the lifted fields by design. We do
# verify both are independently readable and polymorphic-dispatchable
# below; per-version equivalence is covered in definition.test.

# Polymorphic read_dbn() also accepts .zst
query I
SELECT count(*) FROM read_dbn('test/data/test_data.trades.v2.dbn.zst');
----
2

# Polymorphic dispatch must work for every available .dbn.zst pair, not just
# trades. Each row count comes from inspecting the matching uncompressed file.
query I
SELECT count(*) FROM read_dbn('test/data/test_data.mbp-1.v2.dbn.zst');
----
2

query I
SELECT count(*) FROM read_dbn('test/data/test_data.mbo.v3.dbn.zst');
----
2

query I
SELECT count(*) FROM read_dbn('test/data/test_data.ohlcv-1s.v2.dbn.zst');
----
2

query I
SELECT count(*) FROM read_dbn('test/data/test_data.definition.v3.dbn.zst');
----
2

# Polymorphic dispatch returns the same rows as the schema-specific reader.
query I
SELECT count(*) FROM (
    SELECT * FROM read_dbn('test/data/test_data.definition.v3.dbn.zst')
    EXCEPT
    SELECT * FROM read_dbn_definition('test/data/test_data.definition.v3.dbn.zst')
);
----
0

# dbn_metadata() also accepts .zst
query IT
SELECT version::INTEGER, schema
FROM dbn_metadata('test/data/test_data.trades.v2.dbn.zst');
----
2	trades

# dbn_metadata over each .zst fixture in turn.
query IT
SELECT version::INTEGER, schema
FROM dbn_metadata('test/data/test_data.mbp-1.v2.dbn.zst');
----
2	mbp-1

query IT
SELECT version::INTEGER, schema
FROM dbn_metadata('test/data/test_data.mbo.v3.dbn.zst');
----
3	mbo

query IT
SELECT version::INTEGER, schema
FROM dbn_metadata('test/data/test_data.ohlcv-1s.v2.dbn.zst');
----
2	ohlcv-1s

query IT
SELECT version::INTEGER, schema
FROM dbn_metadata('test/data/test_data.definition.v3.dbn.zst');
----
3	definition
